# BV103 — mẫu biến môi trường (không commit giá trị thật).
# Sao chép sang .env.local: `npm run env:bootstrap` rồi điền key từ Supabase Dashboard → Project Settings → API.
# `npm run env:check` sẽ báo lỗi nếu thiếu biến hoặc còn placeholder.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_JWT_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_JWT_HERE

# Tuỳ chọn: URL site cho link đặt lại mật khẩu (email redirect). Local: http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tuỳ chọn: log debug client Supabase khi dev (1 = bật)
# NEXT_PUBLIC_DEBUG_SUPABASE=0

# Pilot 4 module (Quản trị + GSC + VST + Dashboard): chặn /cssd-erp, /giam-sat-nkbv, /quan-ly-cong-viec.
# Chỉ bật trên production pilot. Dev/staging để trống hoặc 0.
# KSNK_PILOT_FOUR_MODULES=1

# Grok optimization pack (20260818 migration)
# BV103_DASHBOARD_QUERY_STALE_MS=90000
# BV103_AUDIT_LOG=1
# KSNK_MODULE_CSSD=1
# KSNK_MODULE_QLCV=1
# E2E_USER_EMAIL=
# E2E_USER_PASSWORD=
# PLAYWRIGHT_BASE_URL=http://localhost:3000
